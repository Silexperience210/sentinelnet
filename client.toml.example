# SentinelNet v0.1.0 — Client configuration (runs alongside LND on the PROTECTED node)

[lnd]
rest_url        = "https://localhost:8080"
tls_cert_path   = "~/.lnd/tls.cert"
macaroon_hex    = "YOUR_ADMIN_MACAROON_HEX"
node_pubkey     = "YOUR_LND_NODE_PUBKEY_HEX"

# One or more sentinels — using multiple provides redundancy
[[sentinels]]
name    = "primary"
url     = "http://YOUR_SENTINEL_IP:9000"
api_key = "SAME_AS_sentinel_api_key_IN_SENTINEL_CONFIG"

# [[sentinels]]
# name    = "backup"
# url     = "http://BACKUP_SENTINEL_IP:9000"
# api_key = "THAT_SENTINELS_API_KEY"

[fees]
base_fee_rate = 10.0               # sat/vbyte fallback (overridden by LND estimate)
fee_tiers     = [1.0, 2.0, 5.0, 10.0]  # 4 pre-signed versions per HTLC
cltv_margin   = 288                # register when this many blocks remain

[watch]
scan_interval_secs  = 30    # periodic scan interval
reregister_margin   = 50    # re-register when <50 blocks before CLTV
scan_force_closing  = true  # Mode B: register real outpoints on force-close
